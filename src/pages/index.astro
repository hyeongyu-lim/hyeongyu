---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, HOME } from "@consts";
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="min-h-[50vh] flex flex-col justify-center">
      <section class="space-y-6 max-w-xl">
        <h1 class="animate text-3xl sm:text-4xl font-semibold tracking-tight text-black dark:text-white">
          {SITE.NAME}
        </h1>
        <p class="animate font-serif text-lg text-black/80 dark:text-white/80">
          {SITE.INSTITUTION}
        </p>
        <p class="animate">
          <Link
            href={`mailto:${SITE.EMAIL}`}
            aria-label={`Email ${SITE.NAME}`}
          >
            {SITE.EMAIL}
          </Link>
        </p>
      </section>
    </div>
  </Container>
</PageLayout>
