---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import BackToPrev from "@components/BackToPrev.astro";
import { RESEARCH } from "@consts";
import { RESEARCH_CATEGORY_LABELS } from "@lib/labels";

export async function getStaticPaths() {
  const research = await getCollection("research");
  return research.map((entry) => ({
    params: { slug: entry.slug },
    props: entry,
  }));
}

type Props = CollectionEntry<"research">;

const entry = Astro.props;
const { Content } = await entry.render();
---

<PageLayout title={entry.data.title} description={RESEARCH.TITLE}>
  <Container>
    <div class="animate">
      <BackToPrev href="/research">Back to research interests</BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate text-xs opacity-60">
        {RESEARCH_CATEGORY_LABELS[entry.data.category]}
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {entry.data.title}
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
