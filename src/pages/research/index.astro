---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { RESEARCH } from "@consts";
import { researchCategories } from "@content/config";
import { RESEARCH_CATEGORY_LABELS } from "@lib/labels";

const entries = (await getCollection("research")).sort(
  (a, b) =>
    a.data.category.localeCompare(b.data.category) ||
    a.data.order - b.data.order,
);

const byCategory = researchCategories.map((category) => ({
  category,
  label: RESEARCH_CATEGORY_LABELS[category],
  items: entries.filter((e) => e.data.category === category),
}));
---

<PageLayout title={RESEARCH.TITLE} description={RESEARCH.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate space-y-3">
        <h1 class="font-semibold text-black dark:text-white">
          Research interests
        </h1>
        <p class="text-sm">
          Topics are organized by category. Add entries under
          <code class="font-sans text-xs">src/content/research/</code>. Markdown
          supports LaTeX, e.g. $\sigma = E \varepsilon$.
        </p>
      </div>

      {
        byCategory.map(
          ({ label, items }) =>
            items.length > 0 && (
              <section class="animate space-y-4">
                <h2 class="font-semibold text-black dark:text-white">{label}</h2>
                <ul class="flex flex-col gap-3">
                  {
                    items.map((item) => (
                      <li>
                        <Link href={`/research/${item.slug}`}>{item.data.title}</Link>
                      </li>
                    ))
                  }
                </ul>
              </section>
            ),
        )
      }
    </div>
  </Container>
</PageLayout>
