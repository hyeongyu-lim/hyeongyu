---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { RESOURCES } from "@consts";
---

<PageLayout title={RESOURCES.TITLE} description={RESOURCES.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <h1 class="animate font-semibold text-black dark:text-white">Resources</h1>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">Books</h2>
        <article>
          <ul class="list-disc list-inside font-serif space-y-1">
            <li>— Add textbooks and references (author, title, edition)</li>
          </ul>
        </article>
      </section>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">Courses</h2>
        <article>
          <ul class="list-disc list-inside font-serif space-y-1">
            <li>— Notable university courses, MOOCs, or workshops</li>
          </ul>
        </article>
      </section>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">Software tools</h2>
        <article>
          <ul class="list-disc list-inside font-serif space-y-1">
            <li>CAD / CAE (SolidWorks, ANSYS, etc.)</li>
            <li>Python scientific stack (NumPy, SciPy, Matplotlib)</li>
            <li>Version control & documentation (Git, LaTeX)</li>
          </ul>
        </article>
      </section>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">
          Learning resources
        </h2>
        <article>
          <ul class="list-disc list-inside font-serif space-y-1">
            <li>— Links to lecture notes, open courseware, and references</li>
          </ul>
        </article>
      </section>
    </div>
  </Container>
</PageLayout>
